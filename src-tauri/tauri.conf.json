{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "Multi-Agent",
  "version": "0.1.0",
  "identifier": "com.multiagent.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../"
  },
  "app": {
    "windows": [
      {
        "title": "Multi-Agent",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 700,
        "center": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true,
        "maximized": false,
        "visible": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "windows": ["main"],
          "permissions": [
            "core:default",
            "shell:allow-open",
            "dialog:allow-open",
            "dialog:allow-save",
            "fs:allow-read",
            "fs:allow-write",
            "notification:default",
            "process:default",
            "opener:default"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "deb", "appimage", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "© 2026 Multi-Agent Team",
    "category": "DeveloperTool",
    "shortDescription": "AI Multi-Agent Collaboration Platform",
    "longDescription": "A desktop application for collaborating with multiple AI experts in parallel."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
